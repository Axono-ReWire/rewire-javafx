{
  "java.format.settings.url": ".vscode/java-formatter.xml",
  "java.format.settings.profile": "EclipseStyle",
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "redhat.java",
  "git.autofetch": true,
  "checkstyle.modules": [
    {
        "name": "Team Style",
        "path": "checkstyle.xml",
        "active": true
    }
  ],
  "java.configuration.updateBuildConfiguration": "interactive",
  "java.debug.settings.vmArgs": "--add-reads com.axono=ALL-UNNAMED --add-opens java.base/java.lang=ALL-UNNAMED --add-opens java.base/java.lang.reflect=ALL-UNNAMED --add-opens java.base/java.nio=ALL-UNNAMED --add-opens java.base/sun.nio.ch=ALL-UNNAMED"
}
